  "avatarInitialsColor": {
    "type": "colorpicker",
    "label": "Avatar Initials Text Color",
    "value": "#FFFFFF"
  },
  "avatarBorderColor": {
    "type": "colorpicker",
    "label": "Avatar Border Color",
    "value": "#a78bfa"
  },
  "showBadges": {
    "type": "dropdown",
    "label": "Show Badges",
    "value": "yes",
    "options": { "yes": "Yes", "no": "No" }
  },
  "badgeSize": {
    "type": "slider",
    "label": "Badge Size",
    "value": 15,
    "min": 10,
    "max": 50,
    "step": 1
  },
  "usernameTransform": {
    "type": "dropdown",
    "label": "Username Text Transform",
    "value": "default",
    "options": { "default": "Default", "uppercase": "Uppercase", "lowercase": "Lowercase" }
  },
  "usernameColorType": {
    "type": "dropdown",
    "label": "Username Color",
    "value": "twitch",
    "options": { "custom": "Custom Color", "twitch": "Twitch Color" }
