  "messageColor": {
    "type": "colorpicker",
    "label": "Message Text Color",
    "value": "#dde9f7"
  },
  "messageFontSize": {
    "type": "slider",
    "label": "Message Font Size",
    "value": 13,
    "min": 10,
    "max": 60,
    "step": 1
