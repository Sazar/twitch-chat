  "borderColor": {
    "type": "colorpicker",
    "label": "Left Border Custom Color",
    "value": "#539ef7"
  },
  "borderWidth": {
    "type": "slider",
    "label": "Left Border Width",
    "value": 5,
    "min": 0,
    "max": 30,
    "step": 1
