  "usernameColor": {
    "type": "colorpicker",
    "label": "Username Custom Color",
    "value": "#a78bfa"
  },
  "usernameFontSize": {
    "type": "slider",
    "label": "Username Font Size",
    "value": 15,
    "min": 10,
    "max": 60,
    "step": 1
