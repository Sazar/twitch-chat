{
  "hideAfter": {
    "type": "number",
    "label": "Hide Message After (seconds)",
    "value": 0
  },
  "hideCommands": {
    "type": "dropdown",
    "label": "Hide Commands (!command)",
    "value": "yes",
    "options": { "yes": "Yes", "no": "No" }
  },
  "maxMessages": {
    "type": "slider",
    "label": "Max Messages Visible",
    "value": 6,
    "min": 1,
    "max": 20,
    "step": 1
  },
  "showAvatars": {
    "type": "dropdown",
    "label": "Show Avatars",
    "value": "yes",
    "options": { "yes": "Yes", "no": "No" }
  },
  "fitContentWidth": {
    "type": "dropdown",
    "label": "Fit Content Width",
    "value": "yes",
    "options": { "yes": "Yes", "no": "No" }
  },
  "avatarMode": {
    "type": "dropdown",
    "label": "Avatar Mode",
    "value": "twitch",
    "options": { "twitch": "Twitch", "initials": "Initials" }
  },
  "avatarSize": {
    "type": "slider",
    "label": "Avatar Size",
    "value": 60,
    "min": 20,
    "max": 120,
    "step": 1
