    "type": "colorpicker",
    "label": "Avatar Initials Background",
    "value": "#AA4DDA"
  },
  "avatarInitialsColor": {
    "type": "colorpicker",
    "label": "Avatar Initials Text Color",
    "value": "#FFFFFF"
  },
  "avatarBorderColor": {
    "type": "colorpicker",
    "label": "Avatar Border Color",
    "value": "#FFFFFF"
  },
  "showBadges": {
    "type": "dropdown",
    "label": "Show Badges",
    "value": "yes",
    "options": { "yes": "Yes", "no": "No" }
  },
  "badgeSize": {
    "type": "slider",
    "label": "Badge Size",
    "value": 20,
    "min": 10,
    "max": 50,
    "step": 1
  },
  "showMessageText": {
    "type": "checkbox",
    "label": "Show Message Text",
    "value": true
  },
  "messageFontSize": {
    "type": "slider",
    "label": "Message Font Size",
    "value": 20,
    "min": 10,
    "max": 60,
    "step": 1
  },
  "usernameTransform": {
    "type": "dropdown",
    "label": "Username Text Transform",
    "value": "default",
    "options": { "default": "Default", "uppercase": "Uppercase", "lowercase": "Lowercase" }
  },
  "usernameColorType": {
    "type": "dropdown",
    "label": "Username Color Type",
    "value": "custom",
    "options": { "custom": "Custom Color", "twitch": "Twitch Color" }
