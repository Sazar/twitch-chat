  "usernameColor": {
    "type": "colorpicker",
    "label": "Username Color (used when type is Custom)",
    "value": "#039BEF"
  },
  "usernameShadowColor": {
    "type": "text",
    "label": "Username Text Shadow Color",
    "value": "rgba(255, 255, 255, 0)"
  },
  "messageColor": {
    "type": "colorpicker",
    "label": "Message Text Color",
    "value": "#CDEDF2"
  },
  "messageBg": {
    "type": "text",
    "label": "Message Background Color",
    "value": "rgba(10,16,40,0.85)"
  },
  "usernameFontSize": {
    "type": "slider",
    "label": "Username Font Size",
    "value": 22,
    "min": 10,
    "max": 60,
    "step": 1
  },
  "borderWidth": {
    "type": "slider",
    "label": "Message Left Border Width",
    "value": 12,
    "min": 0,
    "max": 30,
    "step": 1
  },
  "borderColor": {
    "type": "colorpicker",
    "label": "Message Left Border Color",
    "value": "#039BEF"
  },
  "scrollDirection": {
    "type": "dropdown",
    "label": "Scrolling Direction",
    "value": "left-to-right",
    "options": { "left-to-right": "Left to Right", "right-to-left": "Right to Left" }
  },
  "googleFont": {
    "type": "text",
    "label": "Google Font Name",
    "value": "Montserrat"
  },
  "spacing": {
    "type": "slider",
    "label": "Spacing between messages",
    "value": 12,
    "min": 0,
    "max": 60,
    "step": 1
  },
  "enableTestMessages": {
    "type": "dropdown",
    "label": "Enable Test Messages",
    "value": "no",
    "options": { "yes": "Yes", "no": "No" }
  }
